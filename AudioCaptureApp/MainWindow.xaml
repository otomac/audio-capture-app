<Window x:Class="AudioCaptureApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AudioCaptureApp"
        xmlns:controls="clr-namespace:AudioCaptureApp.Controls"
        mc:Ignorable="d"
        Title="音声キャプチャ" SizeToContent="Height" Width="520"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="#FFE0E0E0">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Height" Value="26"/>
        </Style>
        <Style TargetType="ToggleButton">
            <Setter Property="Height" Value="26"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#FFA0A0A0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Grid.RowSpan="2" BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="0"
                                    Margin="0,8,0,0"/>
                            <Border Grid.Row="0" Padding="4,0" Margin="8,0,0,0"
                                    HorizontalAlignment="Left" VerticalAlignment="Top"
                                    Background="{Binding Background, RelativeSource={RelativeSource AncestorType=Window}}">
                                <ContentPresenter ContentSource="Header"/>
                            </Border>
                            <ContentPresenter Grid.Row="1" Margin="{TemplateBinding Padding}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: 入力デバイス GroupBox -->
        <GroupBox Grid.Row="0" Margin="0,0,0,16">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="入力デバイス" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Button Content="更新" Command="{Binding RefreshDevicesCommand}" Padding="12,2"/>
                </StackPanel>
            </GroupBox.Header>
            <Grid Margin="16,12,16,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="マイク" VerticalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="：" VerticalAlignment="Center" Margin="0,0,8,12"/>
                <ComboBox Grid.Row="0" Grid.Column="2"
                          ItemsSource="{Binding CaptureDevices}"
                          SelectedItem="{Binding SelectedCaptureDevice}"
                          DisplayMemberPath="FriendlyName"
                          IsEnabled="{Binding IsNotBusy}"
                          Margin="0,0,0,12"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="スピーカー" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="：" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox Grid.Row="1" Grid.Column="2"
                          ItemsSource="{Binding RenderDevices}"
                          SelectedItem="{Binding SelectedRenderDevice}"
                          DisplayMemberPath="FriendlyName"
                          IsEnabled="{Binding IsNotBusy}"/>
            </Grid>
        </GroupBox>

        <!-- Row 1: 保存先フォルダ -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="保存先フォルダ" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="：" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox Grid.Column="2" Text="{Binding OutputFolder, Mode=OneWay}" IsReadOnly="True"
                     VerticalAlignment="Stretch" VerticalContentAlignment="Center" Margin="0,0,8,0"/>
            <Button Grid.Column="3" Content="選択" Command="{Binding SelectOutputFolderCommand}" Padding="12,2"/>
        </Grid>

        <!-- Row 2: 録音ボタン -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
            <Button Content="● 録音開始" Command="{Binding StartRecordingCommand}"
                    Width="150" Height="Auto" Padding="20,8" Margin="0,0,16,0" FontSize="14"
                    Background="#FFCC0000" Foreground="White"/>
            <Button Content="■ 停止" Command="{Binding StopRecordingCommand}"
                    Width="150" Height="Auto" Padding="20,8" FontSize="14"/>
        </StackPanel>

        <!-- Row 3: 録音ステータス + 経過時間 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
            <TextBlock Text="{Binding RecordingStatusText}" FontSize="20" Foreground="{Binding RecordingStatusColor}" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="0,0,16,0"/>
            <TextBlock Text="{Binding ElapsedTime}" FontSize="20" FontFamily="Consolas"
                       Foreground="{Binding RecordingStatusColor}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Row 4: 音声ミキサー GroupBox -->
        <GroupBox Grid.Row="4" Header="音声ミキサー" Margin="0,0,0,16">
            <Grid Margin="16,12,16,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="マイク" VerticalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="：" VerticalAlignment="Center" Margin="0,0,8,12"/>
                <controls:LevelMeterControl Grid.Row="0" Grid.Column="2" Level="{Binding MicLevelDb}" Margin="0,0,8,12"/>
                <ToggleButton Grid.Row="0" Grid.Column="3" IsChecked="{Binding IsMicMuted}"
                              MinWidth="60" Padding="8,0" Margin="0,0,0,12" VerticalAlignment="Center">
                    <ToggleButton.Style>
                        <Style TargetType="ToggleButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
                            <Setter Property="Content" Value="ミュート"/>
                            <Style.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Content" Value="ミュート中"/>
                                    <Setter Property="Background" Value="#FFCC0000"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ToggleButton.Style>
                </ToggleButton>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="スピーカー" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="：" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <controls:LevelMeterControl Grid.Row="1" Grid.Column="2" Level="{Binding LoopbackLevelDb}" Margin="0,0,8,0"/>
                <ToggleButton Grid.Row="1" Grid.Column="3" IsChecked="{Binding IsSpeakerMuted}"
                              MinWidth="60" Padding="8,0" VerticalAlignment="Center">
                    <ToggleButton.Style>
                        <Style TargetType="ToggleButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
                            <Setter Property="Content" Value="ミュート"/>
                            <Style.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Content" Value="ミュート中"/>
                                    <Setter Property="Background" Value="#FFCC0000"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ToggleButton.Style>
                </ToggleButton>
            </Grid>
        </GroupBox>

        <!-- Row 5: 文字起こし設定 -->
        <GroupBox Grid.Row="5" Margin="0,0,0,16"
                  AllowDrop="True"
                  DragEnter="TranscriptionGroup_DragOver"
                  DragOver="TranscriptionGroup_DragOver"
                  DragLeave="TranscriptionGroup_DragLeave"
                  Drop="TranscriptionGroup_Drop">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                    <CheckBox Content="録音中にライブ文字起こしする" IsChecked="{Binding TranscriptionEnabled}"
                              VerticalAlignment="Center"
                              IsEnabled="{Binding IsNotBusy}"/>
                </StackPanel>
            </GroupBox.Header>
            <Grid Background="Transparent">
            <Grid Margin="16,12,16,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="モデル" VerticalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="：" VerticalAlignment="Center" Margin="0,0,8,8"/>
                <TextBox Grid.Row="0" Grid.Column="2" Text="{Binding WhisperModelPath, Mode=OneWay}"
                         IsReadOnly="True" VerticalContentAlignment="Center" Margin="0,0,8,8"/>
                <Button Grid.Row="0" Grid.Column="3" Content="選択" Command="{Binding SelectWhisperModelCommand}"
                        Padding="12,2" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="状態" VerticalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="：" VerticalAlignment="Center" Margin="0,0,8,12"/>
                <TextBlock Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Text="{Binding TranscriptionStatus}"
                           VerticalAlignment="Center" Foreground="#FF555555" Margin="0,0,0,12"/>

                <!-- ファイルから文字起こし: 開始/中止ボタン -->
                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4"
                            Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="音声ファイルから文字起こし"
                            Command="{Binding TranscribeFromFileCommand}"
                            Padding="12,2" Margin="0,0,8,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTranscribingFile}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="中止"
                            Command="{Binding CancelFileTranscriptionCommand}"
                            Padding="12,2" Background="#FFCC0000" Foreground="White">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTranscribingFile}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- 進捗表示 -->
                <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4"
                            Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsTranscribingFile}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <ProgressBar IsIndeterminate="True" Width="180" Height="12" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding FileTranscriptionStatus}"
                               VerticalAlignment="Center" Foreground="#FF555555"/>
                </StackPanel>
            </Grid>

                <!-- ドラッグ＆ドロップ用オーバーレイ -->
                <Border x:Name="DropOverlay"
                        Background="#CC1E88E5" BorderBrush="#FF0D47A1" BorderThickness="2"
                        Visibility="Collapsed" IsHitTestVisible="False">
                    <TextBlock Text="ここにドロップして文字起こしを開始"
                               Foreground="White" FontSize="16" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </GroupBox>

        <!-- Row 6: ステータスバー -->
        <Border Grid.Row="6" Background="#FFF0F0F0" Padding="8,4" CornerRadius="2">
            <TextBlock Text="{Binding StatusMessage}" TextTrimming="CharacterEllipsis"
                       Foreground="#FF555555"/>
        </Border>
    </Grid>
</Window>
