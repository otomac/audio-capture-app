<UserControl x:Class="AudioCaptureApp.Controls.LevelMeterControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="16">
    <Grid x:Name="MeterGrid" ClipToBounds="True">
        <!-- Background segments: green | yellow | red -->
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- -60 to -3 dB = 57/63 of range -->
                <ColumnDefinition Width="57*"/>
                <!-- -3 to 0 dB = 3/63 of range -->
                <ColumnDefinition Width="3*"/>
                <!-- 0 to +3 dB = 3/63 of range -->
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>
            <Rectangle Grid.Column="0" Fill="#FF22B14C" RadiusX="2" RadiusY="2"/>
            <Rectangle Grid.Column="1" Fill="#FFFFC800"/>
            <Rectangle Grid.Column="2" Fill="#FFED1C24" RadiusX="2" RadiusY="2"/>
        </Grid>

        <!-- Dark overlay that masks the unlit portion (slides from right) -->
        <Rectangle x:Name="OverlayRect" Fill="#FF2D2D2D" HorizontalAlignment="Right" Width="0"/>
    </Grid>
</UserControl>
